{
  "dashboard": {
    "title": "Royal Exchange - Мониторинг",
    "tags": [
      "royal-exchange",
      "monitoring"
    ],
    "timezone": "browser",
    "schemaVersion": 27,
    "version": 1,
    "refresh": "10s",
    "panels": [
      {
        "id": 1,
        "title": "HTTP Запросы (всего)",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 0
        },
        "targets": [
          {
            "expr": "http_requests_total",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 2,
        "title": "HTTP Ошибки (всего)",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 0
        },
        "targets": [
          {
            "expr": "http_errors_total",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "thresholds"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                },
                {
                  "value": 10,
                  "color": "yellow"
                },
                {
                  "value": 50,
                  "color": "red"
                }
              ]
            },
            "unit": "short"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 3,
        "title": "Активные игры",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 0
        },
        "targets": [
          {
            "expr": "app_active_games",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 4,
        "title": "Активные игроки",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 18,
          "y": 0
        },
        "targets": [
          {
            "expr": "app_active_players",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 5,
        "title": "HTTP Запросы по эндпоинтам",
        "type": "bargauge",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 4
        },
        "targets": [
          {
            "expr": "http_requests_by_endpoint",
            "refId": "A",
            "legendFormat": "{{endpoint}}",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 6,
        "title": "HTTP Запросы по статусам",
        "type": "piechart",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 4
        },
        "targets": [
          {
            "expr": "http_requests_by_status",
            "refId": "A",
            "legendFormat": "{{status}}",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 7,
        "title": "Время ответа (среднее)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 12
        },
        "targets": [
          {
            "expr": "http_request_duration_seconds_avg",
            "refId": "A",
            "legendFormat": "Среднее",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 8,
        "title": "Время ответа (p95)",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 12
        },
        "targets": [
          {
            "expr": "http_request_duration_seconds_p95",
            "refId": "A",
            "legendFormat": "95-й перцентиль",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "s",
            "decimals": 3
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 9,
        "title": "Использование CPU",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 20
        },
        "targets": [
          {
            "expr": "system_cpu_percent",
            "refId": "A",
            "legendFormat": "CPU %",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "min": 0,
            "max": 100,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                {
                  "value": null,
                  "color": "green"
                },
                {
                  "value": 50,
                  "color": "yellow"
                },
                {
                  "value": 80,
                  "color": "red"
                }
              ]
            }
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 10,
        "title": "Использование памяти",
        "type": "timeseries",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 12,
          "y": 20
        },
        "targets": [
          {
            "expr": "system_memory_mb",
            "refId": "A",
            "legendFormat": "Память (MB)",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "unit": "mbytes"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 11,
        "title": "Запросы к БД (всего)",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 0,
          "y": 28
        },
        "targets": [
          {
            "expr": "db_queries_total",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 12,
        "title": "WebSocket подключения",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 6,
          "y": 28
        },
        "targets": [
          {
            "expr": "app_websocket_connections",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "short"
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 13,
        "title": "Uptime (часы)",
        "type": "stat",
        "gridPos": {
          "h": 4,
          "w": 6,
          "x": 12,
          "y": 28
        },
        "targets": [
          {
            "expr": "app_uptime_seconds / 3600",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "fieldConfig": {
          "defaults": {
            "color": {
              "mode": "palette-classic"
            },
            "unit": "hrs",
            "decimals": 2
          }
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      },
      {
        "id": 14,
        "title": "Ошибки по типам",
        "type": "bargauge",
        "gridPos": {
          "h": 8,
          "w": 12,
          "x": 0,
          "y": 32
        },
        "targets": [
          {
            "expr": "http_errors_total",
            "refId": "A",
            "datasource": {
              "type": "prometheus",
              "uid": "prometheus"
            }
          }
        ],
        "options": {
          "orientation": "horizontal",
          "displayMode": "gradient"
        },
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        }
      }
    ],
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "timepicker": {
      "refresh_intervals": [
        "10s",
        "30s",
        "1m",
        "5m",
        "15m",
        "30m",
        "1h",
        "2h",
        "1d"
      ]
    }
  }
}